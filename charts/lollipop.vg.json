{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Australia's All-Time Test Wicket Takers",
    "width": 250,
    "height": 200,
    "data": {
        "url": "data/bowlers.csv",
        "format": {"type": "csv"}
    },
    "layer": [
        {
            "mark": {"type": "bar", "color": "#a5d6a7", "size": 3},
            "encoding": {
                "y": {"field": "bowler", "type": "nominal", "sort": "-x", "axis": {"title": null}},
                "x": {"field": "wickets", "type": "quantitative", "axis": {"title": "Test Wickets"}}
            }
        },
        {
            "mark": {"type": "point", "filled": true, "size": 150, "color": "#1b5e20"},
            "encoding": {
                "y": {"field": "bowler", "type": "nominal", "sort": "-x"},
                "x": {"field": "wickets", "type": "quantitative"},
                "tooltip": [
                    {"field": "bowler", "title": "Bowler"},
                    {"field": "wickets", "title": "Wickets"}
                ]
            }
        }
    ]
}
