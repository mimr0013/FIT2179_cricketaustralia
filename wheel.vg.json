{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Wheel of Victory",
    "subtitle": "Australia's Test wins against each opponent. Each wedge is one nation; the arc's reach and colour show how many Tests Australia has won there.",
    "anchor": "start", "font": "Barlow Condensed, sans-serif", "fontSize": 19, "fontWeight": 600,
    "subtitleFont": "Spectral, Georgia, serif", "subtitleFontSize": 12, "subtitleColor": "#5a6b5d", "subtitlePadding": 6, "offset": 14
  },
  "width": 420,
  "height": 420,
  "data": {"url": "results_by_opp.csv", "format": {"type": "csv"}},
  "layer": [
    {
      "mark": {"type": "arc", "innerRadius": 55, "stroke": "#fffdf8", "strokeWidth": 1.5, "cornerRadius": 3},
      "encoding": {
        "theta": {"field": "opponent", "type": "nominal", "sort": {"field": "won", "order": "descending"}, "title": null},
        "radius": {"field": "won", "type": "quantitative", "scale": {"zero": true, "rangeMin": 55}, "title": "Wins"},
        "color": {"field": "won", "type": "quantitative", "title": "Test wins", "scale": {"scheme": "oranges"}, "legend": {"orient": "right", "gradientLength": 120}},
        "tooltip": [
          {"field": "opponent", "title": "Opponent"},
          {"field": "won", "title": "Wins"},
          {"field": "lost", "title": "Losses"},
          {"field": "matches", "title": "Played"},
          {"field": "win_pct", "title": "Win %"}
        ]
      }
    },
    {
      "mark": {"type": "text", "radiusOffset": 14, "fontSize": 10, "fontWeight": "bold", "color": "#20242e", "font": "Barlow Condensed, sans-serif"},
      "encoding": {
        "theta": {"field": "opponent", "type": "nominal", "sort": {"field": "won", "order": "descending"}, "stack": true},
        "radius": {"field": "won", "type": "quantitative", "scale": {"zero": true, "rangeMin": 55}},
        "text": {"field": "opponent", "type": "nominal"}
      }
    },
    {
      "mark": {"type": "text", "radiusOffset": 14, "fontSize": 9, "color": "#3a4a3c", "dy": 11, "font": "Spectral, Georgia, serif"},
      "encoding": {
        "theta": {"field": "opponent", "type": "nominal", "sort": {"field": "won", "order": "descending"}, "stack": true},
        "radius": {"field": "won", "type": "quantitative", "scale": {"zero": true, "rangeMin": 55}},
        "text": {"field": "won", "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "text", "fontSize": 26, "fontWeight": "bold", "color": "#b5471f", "font": "Barlow Condensed, sans-serif", "radius": 0},
      "encoding": {"text": {"value": "425"}}
    },
    {
      "mark": {"type": "text", "fontSize": 10, "color": "#5a6b5d", "font": "Spectral, Georgia, serif", "radius": 0, "dy": 16},
      "encoding": {"text": {"value": "total wins"}}
    }
  ],
  "config": {"font": "Spectral, Georgia, serif", "view": {"stroke": null}}
}
