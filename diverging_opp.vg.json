{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 250,
  "height": 360,
  "data": {"url": "results_by_opp.csv", "format": {"type": "csv"}},
  "transform": [
    {"calculate": "datum.won", "as": "wins_pos"},
    {"calculate": "-datum.lost", "as": "losses_neg"},
    {"fold": ["wins_pos", "losses_neg"], "as": ["result", "value"]},
    {"calculate": "datum.result === 'wins_pos' ? 'Wins' : 'Losses'", "as": "outcome"},
    {"calculate": "abs(datum.value)", "as": "label_value"}
  ],
  "encoding": {
    "y": {"field": "opponent", "type": "nominal", "title": null, "sort": ["England", "West Indies", "South Africa", "India", "Pakistan", "New Zealand", "Sri Lanka", "Bangladesh", "Zimbabwe"]},
    "x": {"field": "value", "type": "quantitative", "title": "Losses < Matches > Wins", "scale": {"domain": [-130, 170]}, "axis": {"labelExpr": "abs(datum.value)"}}
  },
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadius": 2},
      "encoding": {
        "color": {"field": "outcome", "type": "nominal", "title": null, "scale": {"domain": ["Wins", "Losses"], "range": ["#15462b", "#c8553d"]}, "legend": {"orient": "bottom"}},
        "tooltip": [
          {"field": "opponent", "title": "Opponent"},
          {"field": "won", "title": "Won"},
          {"field": "lost", "title": "Lost"},
          {"field": "matches", "title": "Played"},
          {"field": "win_pct", "title": "Win %"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.value >= 5"}],
      "mark": {"type": "text", "align": "left", "dx": 6, "fontSize": 9, "fontWeight": "bold", "color": "#20242e"},
      "encoding": {"text": {"field": "label_value", "type": "quantitative"}}
    },
    {
      "transform": [{"filter": "datum.value <= -5"}],
      "mark": {"type": "text", "align": "right", "dx": -6, "fontSize": 9, "fontWeight": "bold", "color": "#20242e"},
      "encoding": {"text": {"field": "label_value", "type": "quantitative"}}
    },
    {
      "transform": [
        {"filter": "datum.outcome === 'Wins' && (datum.opponent === 'West Indies' || datum.opponent === 'India')"},
        {"calculate": "datum.opponent === 'India' ? 'Toughest modern rival' : 'Largest win surplus'", "as": "note"}
      ],
      "mark": {"type": "text", "align": "left", "dx": 34, "fontSize": 10, "fontStyle": "italic", "fontWeight": "bold", "color": "#15462b"},
      "encoding": {"text": {"field": "note"}}
    }
  ],
  "config": {"font": "Spectral, Georgia, serif", "view": {"stroke": null}}
}
