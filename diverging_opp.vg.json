{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Who Australia Beats — and Who Fights Back",
    "subtitle": "Wins (right) versus losses (left) against each Test nation, all-time",
    "anchor": "start", "fontSize": 16, "subtitleFontSize": 12, "subtitleColor": "#565b66"
  },
  "width": "container",
  "height": 360,
  "data": {"url": "results_by_opp.csv", "format": {"type": "csv"}},
  "transform": [
    {"calculate": "datum.won", "as": "wins_pos"},
    {"calculate": "-datum.lost", "as": "losses_neg"},
    {"fold": ["wins_pos", "losses_neg"], "as": ["result", "value"]},
    {"calculate": "datum.result === 'wins_pos' ? 'Wins' : 'Losses'", "as": "outcome"},
    {"calculate": "abs(datum.value)", "as": "label_value"}
  ],
  "encoding": {
    "y": {"field": "opponent", "type": "nominal", "title": null, "sort": ["England", "West Indies", "South Africa", "India", "Pakistan", "New Zealand", "Sri Lanka", "Bangladesh", "Zimbabwe"]},
    "x": {"field": "value", "type": "quantitative", "title": "Losses  ←    matches    →  Wins", "axis": {"labelExpr": "abs(datum.value)"}}
  },
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadius": 2},
      "encoding": {
        "color": {"field": "outcome", "type": "nominal", "title": null, "scale": {"domain": ["Wins", "Losses"], "range": ["#15462b", "#c8553d"]}},
        "tooltip": [
          {"field": "opponent", "title": "Opponent"},
          {"field": "won", "title": "Won"},
          {"field": "lost", "title": "Lost"},
          {"field": "matches", "title": "Played"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.value >= 0"}],
      "mark": {"type": "text", "align": "left", "dx": 4, "fontSize": 9, "fontWeight": "bold", "color": "#20242e"},
      "encoding": {"text": {"field": "label_value", "type": "quantitative"}}
    },
    {
      "transform": [{"filter": "datum.value < 0"}],
      "mark": {"type": "text", "align": "right", "dx": -4, "fontSize": 9, "fontWeight": "bold", "color": "#20242e"},
      "encoding": {"text": {"field": "label_value", "type": "quantitative"}}
    }
  ],
  "config": {"font": "Spectral, Georgia, serif", "view": {"stroke": null}}
}
