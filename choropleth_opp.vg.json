{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "A Global Win Rate",
    "subtitle": "Share of Tests Australia has won against each nation. Deeper colour = greater dominance.",
    "anchor": "start", "fontSize": 16, "subtitleFontSize": 12, "subtitleColor": "#565b66"
  },
  "width": 700,
  "height": 420,
  "projection": {"type": "equalEarth"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/ne_110m_admin_0_countries.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape", "fill": "#ece4d3", "stroke": "#fffdf8", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/ne_110m_admin_0_countries.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "transform": [
        {
          "lookup": "properties.NAME",
          "from": {
            "data": {"url": "results_by_opp.csv", "format": {"type": "csv"}},
            "key": "map_name",
            "fields": ["win_pct", "won", "lost", "draw", "matches", "opponent"]
          }
        },
        {"filter": "datum.win_pct != null"}
      ],
      "mark": {"type": "geoshape", "stroke": "#fffdf8", "strokeWidth": 0.6},
      "encoding": {
        "color": {
          "field": "win_pct", "type": "quantitative", "title": "Win %",
          "scale": {"scheme": "teals", "domain": [40, 100]},
          "legend": {"orient": "bottom-left"}
        },
        "tooltip": [
          {"field": "opponent", "title": "Opponent"},
          {"field": "win_pct", "title": "Win %"},
          {"field": "won", "title": "Won"},
          {"field": "lost", "title": "Lost"},
          {"field": "matches", "title": "Played"}
        ]
      }
    }
  ],
  "config": {"view": {"stroke": null}, "font": "Spectral, Georgia, serif"}
}
