{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Australia's All-Time Test Wicket Takers",
  "width": 300,
  "height": 280,
  "data": {"url": "bowlers.csv", "format": {"type": "csv"}},
  "encoding": {
    "y": {"field": "bowler", "type": "nominal", "sort": "-x", "axis": {"title": null}},
    "x": {"field": "wickets", "type": "quantitative", "axis": {"title": "Test Wickets"}}
  },
  "layer": [
    {
      "mark": {"type": "rule", "color": "#d8b6a8", "strokeWidth": 2},
      "encoding": {"x": {"datum": 0}, "x2": {"field": "wickets"}}
    },
    {
      "mark": {"type": "point", "filled": true, "size": 180, "stroke": "#ffffff", "strokeWidth": 1},
      "encoding": {
        "color": {"field": "type", "type": "nominal", "title": "Type", "scale": {"domain": ["Pace", "Spin"], "range": ["#2a7f8e", "#e2a228"]}},
        "tooltip": [
          {"field": "bowler", "title": "Bowler"},
          {"field": "wickets", "title": "Wickets"},
          {"field": "type", "title": "Type"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 11, "fontSize": 9, "fontWeight": "bold", "color": "#20242e"},
      "encoding": {"text": {"field": "wickets", "type": "quantitative"}}
    }
  ],
  "config": {"font": "Spectral, Georgia, serif", "view": {"stroke": null}}
}
