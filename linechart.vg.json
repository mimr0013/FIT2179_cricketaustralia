{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Australia Test Win/Loss Ratio by Decade",
    "width": 300,
    "height": 250,
    "data": {
        "url": "data/winloss.csv",
        "format": {"type": "csv"}
    },
    "layer": [
        {
            "mark": {"type": "area", "color": "#c8e6c9", "opacity": 0.4},
            "encoding": {
                "x": {
                    "field": "decade",
                    "type": "ordinal",
                    "axis": {"title": "Decade"}
                },
                "y": {
                    "field": "ratio",
                    "type": "quantitative",
                    "axis": {"title": "Win / Loss Ratio"}
                }
            }
        },
        {
            "mark": {
                "type": "line",
                "color": "#1b5e20",
                "strokeWidth": 2.5,
                "point": {"color": "#1b5e20", "size": 60}
            },
            "encoding": {
                "x": {"field": "decade", "type": "ordinal"},
                "y": {"field": "ratio", "type": "quantitative"},
                "tooltip": [
                    {"field": "decade", "title": "Decade"},
                    {"field": "ratio", "title": "Win/Loss Ratio"},
                    {"field": "wins", "title": "Wins"},
                    {"field": "losses", "title": "Losses"}
                ]
            }
        },
        {
            "mark": {
                "type": "text",
                "dy": -15,
                "fontSize": 11,
                "color": "#1b5e20",
                "fontWeight": "bold"
            },
            "transform": [
                {"filter": "datum.decade == '1930s' || datum.decade == '2000s'"}
            ],
            "encoding": {
                "x": {"field": "decade", "type": "ordinal"},
                "y": {"field": "ratio", "type": "quantitative"},
                "text": {"field": "decade", "type": "nominal"}
            }
        }
    ]
}