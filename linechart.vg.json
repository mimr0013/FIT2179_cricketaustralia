{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Australia Test Win/Loss Ratio by Decade",
  "width": 250,
  "height": 250,
  "data": {"url": "winloss.csv", "format": {"type": "csv"}},
  "layer": [
    {
      "mark": {"type": "rule", "color": "#9aa0ab", "strokeDash": [4, 4]},
      "encoding": {"y": {"datum": 1}}
    },
    {
      "mark": {"type": "area", "color": "#2a7f8e", "opacity": 0.15},
      "encoding": {
        "x": {"field": "decade", "type": "ordinal", "axis": {"title": "Decade"}},
        "y": {"field": "ratio", "type": "quantitative", "axis": {"title": "Win / Loss Ratio"}}
      }
    },
    {
      "mark": {"type": "line", "color": "#2a7f8e", "strokeWidth": 2.5, "point": {"color": "#1a5560", "size": 60}},
      "encoding": {
        "x": {"field": "decade", "type": "ordinal"},
        "y": {"field": "ratio", "type": "quantitative"},
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "ratio", "title": "Win/Loss Ratio"},
          {"field": "wins", "title": "Wins"},
          {"field": "losses", "title": "Losses"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -15, "fontSize": 11, "color": "#c8553d", "fontWeight": "bold"},
      "transform": [{"filter": "datum.decade == '1940s' || datum.decade == '2000s'"}],
      "encoding": {
        "x": {"field": "decade", "type": "ordinal"},
        "y": {"field": "ratio", "type": "quantitative"},
        "text": {"field": "ratio", "type": "quantitative", "format": ".1f"}
      }
    }
  ],
  "config": {"font": "Spectral, Georgia, serif", "view": {"stroke": null}}
}
